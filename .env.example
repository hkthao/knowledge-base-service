# ── Neo4j ───────────────────────────────────────────────────────────
NEO4J_PASSWORD=changeme-please

# ── Ollama (host) ───────────────────────────────────────────────────
# KB indexer chạy local (.venv): mặc định http://localhost:11434 đã đúng,
# không cần set lại. Chỉ set OLLAMA_URL khi:
#   - KB indexer chạy trong docker và Ollama trên host (Mac/Win):
#         OLLAMA_URL=http://host.docker.internal:11434
#   - Ollama trên server khác:
#         OLLAMA_URL=http://10.0.0.5:11434

# ── Embedding initial index (optional) ──────────────────────────────
# Set để dùng voyage-code-2 cho initial full index (~5–10× nhanh hơn
# Ollama trên CPU). Nếu trống, fallback về Ollama nomic-embed-code.
VOYAGE_API_KEY=

# ── LLM cho synthetic description tiếng Việt ────────────────────────
# Set một trong hai:
#   1) Anthropic Haiku 4.5 (mặc định)
ANTHROPIC_API_KEY=
DESCRIPTION_LLM_BACKEND=anthropic
#   2) Ollama local (Qwen2.5-7B hoặc tương tự)
# DESCRIPTION_LLM_BACKEND=ollama
# DESCRIPTION_LLM_MODEL=qwen2.5:7b

# ── Roslyn service — internal NuGet allowlist (optional) ────────────
# Comma-separated namespace prefix. Calls vào những NS này vẫn tạo CALLS
# edge dù symbol nằm trong NuGet metadata.
INTERNAL_NS_PREFIXES=

# ── Langfuse tracing (optional) ─────────────────────────────────────
# Cả 3 phải set thì mỗi /search mới được trace.
LANGFUSE_HOST=
LANGFUSE_SECRET_KEY=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_NEXTAUTH_SECRET=changeme-nextauth
LANGFUSE_SALT=changeme-salt
